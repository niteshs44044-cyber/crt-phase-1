// Problem Statement 7 - Smart Home Lighting (Motion & Time Based Control)
#include <iostream>
using namespace std;
int main() {
    string dayOrNight;
    bool motionDetected;
    cin >> dayOrNight >> motionDetected;
    if(dayOrNight == "Night" || dayOrNight == "night") {
        if(motionDetected) {
            cout << "LED 100% brightness";
        } else {
            cout << "LED 10% brightness";
        }
    } else {
